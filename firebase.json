{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "**/.*",
      ".agents/**",
      ".firebase/**",
      ".git/**",
      "node_modules/**",
      "**/*.xlsx",
      "**/*.py",
      "admin-seed.json",
      "_dbg.js",
      "mkt_targets.json",
      "reports/**",
      "contract/**",
      "clients/**"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**",
        "headers": [
          {"key": "Cache-Control", "value": "no-store"},
          {"key": "X-Content-Type-Options", "value": "nosniff"},
          {"key": "Referrer-Policy", "value": "strict-origin-when-cross-origin"}
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
